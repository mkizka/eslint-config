{
  "name": "@mkizka/eslint-config",
  "version": "10.0.0",
  "type": "module",
  "description": "ESLint rules for mkizka",
  "repository": {
    "type": "git",
    "url": "https://github.com/mkizka/eslint-config.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "all": "run-s build format 'test -u'",
    "build": "tsc --project tsconfig.build.json",
    "format": "eslint . --fix && prettier --write .",
    "lint": "eslint . && prettier --check .",
    "prepare": "husky",
    "preview": "pnpm -s dlx @eslint/config-inspector@latest",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">= 10"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "5.8.5",
    "@eslint/js": "^10.0.1",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.0.0",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@tsconfig/node-lts": "24.0.0",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "eslint": "10.4.0",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "17.0.5",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.3",
    "prettier-plugin-pkg": "0.22.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.ts": "eslint --fix"
  }
}

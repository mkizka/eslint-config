{
  "name": "@mkizka/eslint-config",
  "version": "10.0.0",
  "type": "module",
  "description": "ESLint rules for mkizka",
  "repository": {
    "type": "git",
    "url": "https://github.com/mkizka/eslint-config.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "all": "run-s build format 'test -u'",
    "build": "tsc --project tsconfig.build.json",
    "format": "eslint . --fix && prettier --write .",
    "lint": "eslint . && prettier --check .",
    "prepare": "husky",
    "preview": "pnpm -s dlx @eslint/config-inspector@latest",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">= 10"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "5.9.2",
    "@eslint/js": "^10.0.1",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.0.0",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@tsconfig/node-lts": "24.0.0",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "eslint": "10.5.0",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "17.0.8",
    "npm-run-all2": "9.0.2",
    "prettier": "3.8.4",
    "prettier-plugin-pkg": "0.22.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.ts": "eslint --fix"
  }
}

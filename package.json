{
  "name": "@mkizka/eslint-config",
  "version": "10.0.0",
  "type": "module",
  "description": "ESLint rules for mkizka",
  "repository": {
    "type": "git",
    "url": "https://github.com/mkizka/eslint-config.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "all": "run-s build format 'test -u'",
    "build": "tsc --project tsconfig.build.json",
    "format": "eslint . --fix && prettier --write .",
    "lint": "eslint . && prettier --check .",
    "prepare": "husky",
    "preview": "pnpm -s dlx @eslint/config-inspector@latest",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">= 10"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "5.14.10",
    "@eslint/js": "^10.0.1",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.0.0",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@tsconfig/node-lts": "24.0.0",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "17.0.8",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.5",
    "prettier-plugin-pkg": "0.22.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.ts": "eslint --fix"
  }
}

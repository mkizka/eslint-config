{
  "name": "@mkizka/eslint-config",
  "version": "9.0.0",
  "type": "module",
  "description": "ESLint rules for mkizka",
  "repository": {
    "type": "git",
    "url": "https://github.com/mkizka/eslint-config.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "all": "run-s build format 'test -u'",
    "build": "tsc --project tsconfig.build.json",
    "format": "eslint . --fix && prettier --write .",
    "lint": "eslint . && prettier --check .",
    "prepare": "husky",
    "preview": "pnpm -s dlx @eslint/config-inspector@latest",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">= 10"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.0.0",
    "typescript-eslint": "^8.56.1"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@tsconfig/node-lts": "24.0.0",
    "@types/node": "24.12.0",
    "eslint": "10.0.3",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "16.4.0",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "prettier-plugin-pkg": "0.22.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.ts": "eslint --fix"
  }
}
